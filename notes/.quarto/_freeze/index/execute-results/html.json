    "engine": "knitr",
    "markdown": "<!-- Complete dogshit here -->\n<div id=\"pp-wrap\" style=\"width:100%; display:flex; justify-content:center; margin:0; padding:0; margin-bottom: -16px;\">\n  <canvas id=\"pp-canvas\" style=\"display:block; width:100%; max-width:980px; height:auto; cursor:pointer;\"></canvas>\n</div>\n\n<script>\n(() => {\n  // ============================================================\n  // Tunable settings\n  // ============================================================\n  const WIDTH = 980;\n  const HEIGHT = 350;\n\n  // Mask generation\n  const MASK_RES = 1;\n  const NOISE_SCALE_1 = 0.010;\n  const NOISE_SCALE_2 = 0.022;\n  const NOISE_SCALE_3 = 0.055;\n  const THRESHOLD = 0.485;\n  const WARP = 45;\n  const BLUR_PASSES = 2;\n\n  // Point process\n  const LAMBDA = 115;\n  const MEAN_LIFETIME = 8.5;\n  const MAX_POINTS = 500;\n  const POINT_RADIUS = 5.6;\n  const STROKE_WIDTH = 1.7;\n  const POINT_FILL = \"#f2f2f2\";\n  const POINT_STROKE = \"#2b2b2b\";\n\n  // Appearance\n  const BORDER_COLOR = \"#666\";\n  const BORDER_WIDTH = 1.5;\n  const BLACK = \"#000000\";\n  const WHITE = \"#ffffff\";\n\n  // ============================================================\n  // Setup\n  // ============================================================\n  const canvas = document.getElementById(\"pp-canvas\");\n  const ctx = canvas.getContext(\"2d\");\n  canvas.width = WIDTH;\n  canvas.height = HEIGHT;\n\n  const off = document.createElement(\"canvas\");\n  const offCtx = off.getContext(\"2d\");\n  off.width = WIDTH;\n  off.height = HEIGHT;\n\n  const maskCanvas = document.createElement(\"canvas\");\n  const maskCtx = maskCanvas.getContext(\"2d\");\n\n  const maskW = Math.floor(WIDTH / MASK_RES);\n  const maskH = Math.floor(HEIGHT / MASK_RES);\n  maskCanvas.width = maskW;\n  maskCanvas.height = maskH;\n\n  let spawnMask = new Uint8Array(maskW * maskH);\n  let whitePixels = [];\n  let valueGrid = new Map();\n  let rng = null;\n\n  // ============================================================\n  // RNG\n  // ============================================================\n  function mulberry32(a) {\n    return function() {\n      let t = a += 0x6D2B79F5;\n      t = Math.imul(t ^ (t >>> 15), t | 1);\n      t ^= t + Math.imul(t ^ (t >>> 7), t | 61);\n      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;\n    };\n  }\n\n  function reseed(seed = (Date.now() ^ Math.floor(Math.random() * 1e9)) >>> 0) {\n    rng = mulberry32(seed);\n    valueGrid = new Map();\n  }\n\n  // ============================================================\n  // Noise helpers\n  // ============================================================\n  function hash2(ix, iy) {\n    const key = `${ix},${iy}`;\n    if (!valueGrid.has(key)) valueGrid.set(key, rng());\n    return valueGrid.get(key);\n  }\n\n  function smoothstep(t) {\n    return t * t * (3 - 2 * t);\n  }\n\n  function lerp(a, b, t) {\n    return a + (b - a) * t;\n  }\n\n  function valueNoise(x, y, scale) {\n    const sx = x * scale;\n    const sy = y * scale;\n\n    const x0 = Math.floor(sx);\n    const y0 = Math.floor(sy);\n    const x1 = x0 + 1;\n    const y1 = y0 + 1;\n\n    const tx = smoothstep(sx - x0);\n    const ty = smoothstep(sy - y0);\n\n    const v00 = hash2(x0, y0);\n    const v10 = hash2(x1, y0);\n    const v01 = hash2(x0, y1);\n    const v11 = hash2(x1, y1);\n\n    const a = lerp(v00, v10, tx);\n    const b = lerp(v01, v11, tx);\n    return lerp(a, b, ty);\n  }\n\n  function fbm(x, y) {\n    return (\n      0.56 * valueNoise(x, y, NOISE_SCALE_1) +\n      0.29 * valueNoise(x + 173.1, y - 91.7, NOISE_SCALE_2) +\n      0.15 * valueNoise(x - 71.3, y + 44.2, NOISE_SCALE_3)\n    );\n  }\n\n  // ============================================================\n  // Mask generation\n  // ============================================================\n  function generateMask() {\n    const img = maskCtx.createImageData(maskW, maskH);\n    const data = img.data;\n    const raw = new Float32Array(maskW * maskH);\n\n    for (let j = 0; j < maskH; j++) {\n      for (let i = 0; i < maskW; i++) {\n        const idx = j * maskW + i;\n        const x = i * MASK_RES;\n        const y = j * MASK_RES;\n\n        const wx = x + WARP * (fbm(x + 400, y + 100) - 0.5);\n        const wy = y + WARP * (fbm(x - 200, y + 700) - 0.5);\n\n        let z = fbm(wx, wy);\n\n        const ridges =\n          Math.abs(fbm(wx + 80, wy - 120) - 0.5) +\n          0.8 * Math.abs(fbm(wx - 250, wy + 40) - 0.5);\n\n        z = 0.72 * z + 0.28 * ridges;\n        raw[idx] = z;\n      }\n    }\n\n    let cur = raw;\n    for (let pass = 0; pass < BLUR_PASSES; pass++) {\n      const nxt = new Float32Array(maskW * maskH);\n      for (let j = 0; j < maskH; j++) {\n        for (let i = 0; i < maskW; i++) {\n          let sum = 0;\n          let cnt = 0;\n          for (let dy = -1; dy <= 1; dy++) {\n            for (let dx = -1; dx <= 1; dx++) {\n              const xx = i + dx;\n              const yy = j + dy;\n              if (xx >= 0 && xx < maskW && yy >= 0 && yy < maskH) {\n                sum += cur[yy * maskW + xx];\n                cnt++;\n              }\n            }\n          }\n          nxt[j * maskW + i] = sum / cnt;\n        }\n      }\n      cur = nxt;\n    }\n\n    whitePixels = [];\n\n    for (let j = 0; j < maskH; j++) {\n      for (let i = 0; i < maskW; i++) {\n        const idx = j * maskW + i;\n        const v = cur[idx];\n\n        const isWhite = v < THRESHOLD ? 1 : 0;\n        spawnMask[idx] = isWhite;\n\n        if (isWhite) whitePixels.push(idx);\n\n        const c = isWhite ? 255 : 0;\n        const k = idx * 4;\n        data[k] = c;\n        data[k + 1] = c;\n        data[k + 2] = c;\n        data[k + 3] = 255;\n      }\n    }\n\n    maskCtx.putImageData(img, 0, 0);\n  }\n\n  function drawBackground() {\n    offCtx.clearRect(0, 0, WIDTH, HEIGHT);\n    offCtx.fillStyle = WHITE;\n    offCtx.fillRect(0, 0, WIDTH, HEIGHT);\n    offCtx.imageSmoothingEnabled = true;\n    offCtx.drawImage(maskCanvas, 0, 0, WIDTH, HEIGHT);\n    offCtx.lineWidth = BORDER_WIDTH;\n    offCtx.strokeStyle = BORDER_COLOR;\n    offCtx.strokeRect(0.5, 0.5, WIDTH - 1, HEIGHT - 1);\n  }\n\n  // ============================================================\n  // Point process\n  // ============================================================\n  function sampleSpawnPoint() {\n    if (whitePixels.length === 0) return null;\n\n    const idx = whitePixels[Math.floor(rng() * whitePixels.length)];\n    const j = Math.floor(idx / maskW);\n    const i = idx - j * maskW;\n\n    return {\n      x: (i + rng()) * MASK_RES,\n      y: (j + rng()) * MASK_RES\n    };\n  }\n\n  function expSample(mean) {\n    return -mean * Math.log(1 - rng());\n  }\n\n  const points = [];\n  let lastTime = performance.now();\n\n  function refillPoints() {\n    points.length = 0;\n    for (let i = 0; i < Math.round(LAMBDA * 0.9); i++) {\n      const pt = sampleSpawnPoint();\n      if (pt) {\n        const lifetime = expSample(MEAN_LIFETIME);\n        points.push({\n          x: pt.x,\n          y: pt.y,\n          age: rng() * lifetime,\n          lifetime\n        });\n      }\n    }\n  }\n\n  function maybeSpawn(dt) {\n    const birthRate = LAMBDA / MEAN_LIFETIME;\n    let expectedBirths = birthRate * dt;\n\n    while (expectedBirths > 0) {\n      const p = Math.min(1, expectedBirths);\n      if (rng() < p) {\n        const pt = sampleSpawnPoint();\n        if (pt && points.length < MAX_POINTS) {\n          points.push({\n            x: pt.x,\n            y: pt.y,\n            age: 0,\n            lifetime: expSample(MEAN_LIFETIME)\n          });\n        }\n      }\n      expectedBirths -= 1;\n    }\n  }\n\n  function update(dt) {\n    maybeSpawn(dt);\n\n    for (let i = points.length - 1; i >= 0; i--) {\n      points[i].age += dt;\n      if (points[i].age >= points[i].lifetime) {\n        points.splice(i, 1);\n      }\n    }\n  }\n\n  function drawPoints() {\n    for (const p of points) {\n      const t = p.age / p.lifetime;\n      let alpha = 1;\n      if (t < 0.08) alpha = t / 0.08;\n      else if (t > 0.88) alpha = (1 - t) / 0.12;\n\n      ctx.globalAlpha = Math.max(0, Math.min(1, alpha));\n\n      ctx.beginPath();\n      ctx.arc(p.x, p.y, POINT_RADIUS, 0, Math.PI * 2);\n      ctx.fillStyle = POINT_FILL;\n      ctx.fill();\n      ctx.lineWidth = STROKE_WIDTH;\n      ctx.strokeStyle = POINT_STROKE;\n      ctx.stroke();\n    }\n    ctx.globalAlpha = 1;\n  }\n\n  function frame(now) {\n    const dt = Math.min(0.05, (now - lastTime) / 1000);\n    lastTime = now;\n\n    update(dt);\n\n    ctx.clearRect(0, 0, WIDTH, HEIGHT);\n    ctx.drawImage(off, 0, 0);\n    drawPoints();\n\n    requestAnimationFrame(frame);\n  }\n\n  // ============================================================\n  // Regenerate on click\n  // ============================================================\n  function regenerate() {\n    reseed();\n    generateMask();\n    drawBackground();\n    refillPoints();\n  }\n\n  canvas.addEventListener(\"click\", regenerate);\n\n  // ============================================================\n  // Initialise\n  // ============================================================\n  regenerate();\n  requestAnimationFrame(frame);\n})();\n</script>\n\n# Preface {.unnumbered}\n\nThis webpage serves as both documentation for the `cscp` package, as well as \nan up-to-date reference for my thesis progress.\n\nSkip to:\n\n<div class=\"cta-container\">\n\n<a href=\"thesis/cscp_preface.html\" class=\"cta-button secondary\">\n📘 CSCP I (Thesis Material)\n</a>\n\n<a href=\"thesis/lgcp_motivation.html\" class=\"cta-button secondary\">\n📘 CSCP II (Thesis Material)\n</a>\n\n<a href=\"package_docs/basics.html\" class=\"cta-button secondary\">\n📦 Package Documentation\n</a>\n\n</div>\n## Installation\n\nYou can install the `cscp` package using `devtools::install_github()`:\n\n\n::: {.cell}\n\n```{.r .cell-code}\ndevtools::install_github(\"https://github.com/JosephReps/coxLab.git\")\n```\n:::\n\n\n## Usage\n\nUnder construction...\n\n\n\n\n\n",
